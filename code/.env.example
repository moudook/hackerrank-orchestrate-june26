# --- LLM Provider Configuration ---
# Choose your provider and set the corresponding model + API key.
# The pipeline uses LiteLLM to support all major providers.

# Provider: gemini | openai | anthropic | xai | cohere | groq | together | etc.
LLM_PROVIDER=gemini

# Model string: use LiteLLM format (provider/model_name)
#   Gemini: gemini/gemini-2.0-flash | gemini/gemini-1.5-flash
#   OpenAI: openai/gpt-4o | openai/gpt-4o-mini
#   Anthropic: anthropic/claude-sonnet-4-20250514
#   xAI: xai/grok-2-vision
#   Groq: groq/llama-3.2-90b-vision
LLM_MODEL=gemini/gemini-2.0-flash

# Vision model (can be same or different from LLM_MODEL)
VISION_MODEL=gemini/gemini-2.0-flash

# API key for your primary provider (used by LLM_PROVIDER).
# For Gemini, you can use either LLM_API_KEY or GEMINI_API_KEY.
LLM_API_KEY=your-key-here

# Fallback chain: comma-separated list of model strings to try if the primary fails.
# Each fallback model uses its own provider env vars (OPENAI_API_KEY, ANTHROPIC_API_KEY, etc.)
# Example: openai/gpt-4o,anthropic/claude-sonnet-4-20250514
LLM_FALLBACK_CHAIN=

# --- Pipeline Settings ---
MAX_IMAGES_PER_CALL=4
RATE_LIMIT_RPM=2000
RATE_LIMIT_TPM=4000000
CACHE_ENABLED=true
