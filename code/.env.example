# --- LLM Provider Configuration ---
# Choose your provider and set the corresponding model + API key.
# The pipeline uses LiteLLM to support all major providers.

# Provider: gemini | openai | anthropic | xai | cohere | groq | together | etc.
LLM_PROVIDER=gemini

# Model string: use LiteLLM format (provider/model_name)
#   Gemini:      gemini/gemini-2.5-flash-lite | gemini/gemini-2.5-flash | gemini/gemini-3-flash-preview
#   OpenAI:      openai/gpt-4o | openai/gpt-4o-mini
#   Anthropic:   anthropic/claude-sonnet-4-20250514
#   Groq:        groq/llama-3.2-90b-vision-preview (free tier)
#   OpenRouter:  openrouter/meta-llama/llama-3.2-90b-vision-instruct (free tier)
#   Together:    together_ai/meta-llama/Llama-3.2-90B-Vision-Instruct-Turbo
LLM_MODEL=gemini/gemini-2.5-flash-lite

# Vision model (can be same or different from LLM_MODEL)
VISION_MODEL=gemini/gemini-2.5-flash-lite

# API key for your primary provider.
# Provider-specific env vars (GEMINI_API_KEY, OPENAI_API_KEY, etc.) also work.
# LiteLLM auto-detects the right key per provider.
LLM_API_KEY=your-key-here

# Fallback chain: comma-separated model strings to try if primary fails.
# Each uses its own provider env vars (OPENAI_API_KEY, ANTHROPIC_API_KEY, GROQ_API_KEY, etc.)
# Example: gemini/gemini-3-flash-preview,groq/llama-3.2-90b-vision-preview,openrouter/meta-llama/llama-3.2-90b-vision-instruct
LLM_FALLBACK_CHAIN=

# --- Pipeline Settings ---
MAX_IMAGES_PER_CALL=4
RATE_LIMIT_RPM=2000
RATE_LIMIT_TPM=4000000
CACHE_ENABLED=true
